@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap');
@import "tailwindcss";
@plugin "@tailwindcss/typography";

@theme {
  /* Dynamic mappings based on standard variables */
  --color-parchment: var(--parchment);
  --color-terracotta: var(--accent);
  --color-coral: var(--coral);
  --color-charcoal: var(--charcoal);
  --color-ivory: var(--ivory);

  /* Surfaces */
  --color-warm-sand: var(--warm-sand);
  --color-dark-surface: var(--dark-surface);
  --color-surface-elevated: var(--surface-elevated);
  --color-surface-sunken: var(--surface-sunken);
  --color-surface-code: var(--surface-code);

  /* Text neutrals */
  --color-charcoal-warm: var(--charcoal-warm);
  --color-olive-gray: var(--olive-gray);
  --color-stone-gray: var(--stone-gray);
  --color-warm-silver: var(--warm-silver);
  --color-text-quiet: var(--text-quiet);
  --color-text-muted: var(--text-muted);
  --color-text-strong: var(--text-strong);

  /* Borders & Rings */
  --color-border-cream: var(--border-cream);
  --color-border-warm: var(--border-warm);
  --color-ring-warm: var(--ring-warm);
  --color-ring-subtle: var(--ring-subtle);
  --color-ring-focus: var(--ring-focus);

  /* Semantic */
  --color-error: var(--error);
  --color-focus: var(--focus);

  /* Aliases */
  --color-bg: var(--parchment);
  --color-card: var(--ivory);
  --color-text: var(--charcoal);
  --color-border: var(--border-cream);
  --color-accent: var(--accent);

  /* Motion tokens */
  --motion-fast: var(--motion-fast);
  --motion-base: var(--motion-base);
  --motion-slow: var(--motion-slow);
}

:root {
  --parchment: #f5f4ed;
  --coral: #d97757;
  --charcoal: #141413;
  --ivory: #faf9f5;
  --warm-sand: #e8e6dc;
  --dark-surface: #30302e;
  --charcoal-warm: #4d4c48;
  --olive-gray: #5e5d59;
  --stone-gray: #87867f;
  --warm-silver: #b0aea5;
  --border-cream: #f0eee6;
  --border-warm: #e8e6dc;
  --ring-warm: #d1cfc5;
  --error: #b53333;
  --focus: #3898ec;

  /* New surfaces */
  --surface-elevated: #ffffff;
  --surface-sunken: #f0eee6;
  --surface-code: #30302e;

  /* New text tokens */
  --text-quiet: #b0aea5;
  --text-muted: #87867f;
  --text-strong: #141413;

  /* New ring tokens */
  --ring-subtle: #f0eee6;
  --ring-focus: #3898ec;

  /* Motion tokens */
  --motion-fast: 120ms cubic-bezier(0.2, 0, 0, 1);
  --motion-base: 200ms cubic-bezier(0.2, 0, 0, 1);
  --motion-slow: 320ms cubic-bezier(0.2, 0, 0, 1);

  /* Accent presets for color picker */
  --color-terracotta-preview: #c96442;
  --color-sage-preview: #648c71;
  --color-ocean-preview: #3b7b99;
  --color-plum-preview: #845a82;
  --color-gold-preview: #c79532;
  --accent: var(--color-terracotta-preview);
}

[data-theme="dark"] {
  --parchment: #1c1c1a;
  --coral: #e28f73;
  --charcoal: #faf9f5;
  --ivory: #26261f;
  --warm-sand: #2e2d2a;
  --dark-surface: #f5f4ed;
  --charcoal-warm: #d1cfc5;
  --olive-gray: #b0aea5;
  --stone-gray: #87867f;
  --warm-silver: #5e5d59;
  --border-cream: #3a3935;
  --border-warm: #4d4c48;
  --ring-warm: #5e5d59;
  --error: #e57373;

  /* New dark surfaces */
  --surface-elevated: #30302e;
  --surface-sunken: #1a1a19;
  --surface-code: #3a3935;

  /* New dark text */
  --text-quiet: #5e5d59;
  --text-muted: #87867f;
  --text-strong: #faf9f5;

  /* New dark rings */
  --ring-subtle: #3a3935;
}

[data-accent="sage"] { --accent: var(--color-sage-preview); }
[data-accent="ocean"] { --accent: var(--color-ocean-preview); }
[data-accent="plum"] { --accent: var(--color-plum-preview); }
[data-accent="gold"] { --accent: var(--color-gold-preview); }
[data-accent="terracotta"] { --accent: var(--color-terracotta-preview); }

html[data-font-size="compact"] { font-size: 12px; }
html[data-font-size="default"] { font-size: 14px; }
html[data-font-size="comfortable"] { font-size: 16px; }

html {
  font-family: 'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
  background-color: var(--color-bg);
  color: var(--color-text);
}

.font-serif {
  font-family: Georgia, 'Times New Roman', serif;
}

.font-mono {
  font-family: 'JetBrains Mono', ui-monospace, 'SF Mono', Monaco, monospace;
}

::selection {
  background-color: var(--color-accent);
  color: var(--color-ivory);
}

/* Typing indicator dots */
@keyframes typing-dot {
  0%, 60%, 100% {
    transform: translateY(0);
    opacity: 0.4;
  }
  30% {
    transform: translateY(-4px);
    opacity: 1;
  }
}

.typing-dot {
  animation: typing-dot 1.2s ease-in-out infinite;
}
.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}
.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

/* Entrance animation for messages */
@keyframes message-slide-up {
  0% {
    opacity: 0;
    transform: translateY(10px);
  }
  100% {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-message-slide-up {
  animation: message-slide-up 0.3s ease-out forwards;
  will-change: transform, opacity;
}

/* Fade in animation */
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

.animate-fade-in {
  animation: fade-in var(--motion-base) forwards;
}

/* Caret blink for streaming cursor */
@keyframes caret-blink {
  0%, 50% { opacity: 1; }
  51%, 100% { opacity: 0; }
}

.animate-caret-blink {
  animation: caret-blink 1s step-end infinite;
}

/* Scale in for popovers */
@keyframes scale-in {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

.animate-scale-in {
  animation: scale-in var(--motion-fast) ease-out forwards;
}

.contain-content {
  contain: content;
}

/* Prose warm palette */
.prose {
  --tw-prose-body: var(--charcoal-warm);
  --tw-prose-headings: var(--charcoal);
  --tw-prose-links: var(--accent);
  --tw-prose-bold: var(--charcoal);
  --tw-prose-counters: var(--stone-gray);
  --tw-prose-bullets: var(--warm-silver);
  --tw-prose-hr: var(--border-cream);
  --tw-prose-quotes: var(--charcoal-warm);
  --tw-prose-quote-borders: var(--border-warm);
  --tw-prose-captions: var(--stone-gray);
  --tw-prose-code: var(--charcoal);
  --tw-prose-pre-code: var(--ivory);
  --tw-prose-pre-bg: var(--dark-surface);
  --tw-prose-th-borders: var(--border-warm);
  --tw-prose-td-borders: var(--border-cream);
}

/* Reduced motion */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
}
